<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="uno.zhuchen.echonotejava.Mapper.CapsulesMapper">
    <insert id="addMoodForCapsules">
        INSERT INTO capsules_moods(capsule_id, mood_id) VALUES
        (#{capsulesId}, #{moodId})
    </insert>
    <delete id="deleteMoodByCapsulesId">
        DELETE FROM capsules_moods WHERE capsule_id = #{id}
    </delete>
    <delete id="deleteMoodByCapsules">
        DELETE FROM capsules_moods WHERE capsule_id = #{id}
    </delete>
    <insert id="addMoodForCapsule">
        <if test="moods != null and moods.size() > 0">
            INSERT INTO capsules_moods(capsule_id, mood_id) VALUES
            <foreach collection="moods" item="mood" separator=",">
                (#{id}, #{mood.id})
            </foreach>
        </if>
    </insert>
</mapper>